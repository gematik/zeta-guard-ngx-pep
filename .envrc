# direnv scripts are always interpreted with bash regardless of user shell
# shellcheck shell=bash

# optionally source .envrc.local to allow developer-specific environment config
# .envrc.local is in .gitignore
source_env_if_exists ./.envrc.local

export MACOSX_DEPLOYMENT_TARGET=15.0
# -W*: libjade-sys, -g: enable debug symbols
export CFLAGS="${CFLAGS:+"$CFLAGS "}-Wno-error -Wno-error=unused-command-line-argument -g"

export IT_POPP_P12="$PWD/misc/popp-token-Server-Sim-nist-komp61.p12"
export IT_POPP_P12_ALIAS="alias"
export IT_POPP_P12_PASS="00"

# --- ossl_hsm ---

# $PWD in direnv scripts is the directory that contains `.envrc`
export OPENSSL_CONF=$PWD/ossl_hsm/openssl.cnf

# Render openssl.cnf for interactive usage; it should contain absolute paths.
render_opensslcnf() {
	cat <<-EOF >"$OPENSSL_CONF"
		openssl_conf = openssl_init

		[openssl_init]
		providers = provider_sect

		[provider_sect]
		ossl_hsm = ossl_hsm_sect
		default = default_sect

		[ossl_hsm_sect]
		module = $PWD/target/debug/libossl_hsm.so
		activate = 1

		[default_sect]
		activate = 1
	EOF
}

render_opensslcnf
